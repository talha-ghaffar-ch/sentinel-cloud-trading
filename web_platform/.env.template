# ============================================================
#  SENTINEL CLOUD TRADING — WEB PLATFORM ENVIRONMENT
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git (see .gitignore).
# ============================================================

# ── AWS ───────────────────────────────────────────────────────
# On EC2/Elastic Beanstalk, prefer an IAM instance profile and leave
# the access keys blank. Set them only for local development.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── RDS PostgreSQL ────────────────────────────────────────────
RDS_HOST=YOUR_RDS_ENDPOINT_HERE
RDS_PORT=5432
RDS_NAME=sentinel
RDS_USER=sentinel_app
RDS_PASSWORD=YOUR_RDS_PASSWORD_HERE

# ── DynamoDB table names ──────────────────────────────────────
DYNAMO_LIVE_STATE_TABLE=Sentinel_Live_State
DYNAMO_COMMANDS_TABLE=Sentinel_Commands
DYNAMO_NOTIFICATIONS_TABLE=Sentinel_Notifications

# ── Flask ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=GENERATE_AND_PASTE_HERE
FLASK_ENV=production
PORT=80
