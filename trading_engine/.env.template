# ============================================================
#  SENTINEL CLOUD TRADING — TRADING ENGINE ENVIRONMENT
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git (see .gitignore).
# ============================================================

# ── AWS ───────────────────────────────────────────────────────
# On EC2, prefer an IAM instance profile and leave the keys blank.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── RDS PostgreSQL ────────────────────────────────────────────
RDS_HOST=YOUR_RDS_ENDPOINT_HERE
RDS_PORT=5432
RDS_NAME=sentinel
RDS_USER=sentinel_app
RDS_PASSWORD=YOUR_RDS_PASSWORD_HERE

# ── DynamoDB table names ──────────────────────────────────────
DYNAMO_LIVE_STATE_TABLE=Sentinel_Live_State
DYNAMO_COMMANDS_TABLE=Sentinel_Commands
DYNAMO_NOTIFICATIONS_TABLE=Sentinel_Notifications

# ── Engine configuration ──────────────────────────────────────
TRADING_SYMBOL=XAUUSDm
MAGIC_NUMBER=777999
BASE_LOT=0.01
MAX_DAILY_DRAWDOWN=10.0
COOLDOWN_SECONDS=180

# ── Strategy parameters (PROPRIETARY) ─────────────────────────
# The values below are NEUTRAL PLACEHOLDERS. The production-tuned
# values are proprietary and are not published in this repository.
# Set your own tuned values here in a private deployment.
RECOVERY_MULTIPLIER=1.0
RISK_REWARD=2.0
SIGNAL_CONFIDENCE_MIN=0.60
SIGNAL_CONFIDENCE_RECOVERY=0.70
RECOVERY_LOT_CAP_MULT=3.0
ATR_SL_MULTIPLIER=1.5
